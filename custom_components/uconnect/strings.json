{
    "title": "UConnect (T-Mobile)",
    "config": {
        "step": {
            "user": {
                "title": "UConnect API Authentication",
                "description": "Connect your UConnect-enabled Stellantis vehicle (Jeep, RAM, Dodge, Chrysler, Fiat, Alfa Romeo, Maserati) to Home Assistant using your UConnect account credentials. The integration will automatically detect your vehicle brand and region.",
                "data": {
                    "username": "Username / Email",
                    "password": "Password",
                    "pin": "Security PIN (optional)",
                    "disable_tls_verification": "Disable TLS certificate verification"
                }
            },
            "reauth_confirm": {
                "title": "Re-authenticate UConnect",
                "description": "Your UConnect session has expired. Click Submit to reauthenticate."
            }
        },
        "abort": {
            "already_configured": "This account is already configured.",
            "reauth_successful": "Re-authentication was successful."
        },
        "error": {
            "invalid_auth": "Authentication failed. Check your credentials and ensure your vehicle uses UConnect (not SiriusXM Guardian).",
            "no_vehicles": "Login succeeded but no vehicles were found. Ensure your vehicle appears in the official Uconnect app. For 2013–2018 Dodge/Chrysler vehicles, see the README Troubleshooting section for legacy UConnect Access guidance.",
            "unknown": "An unexpected error occurred. Check the Home Assistant logs."
        }
    },
    "options": {
        "step": {
            "init": {
                "title": "UConnect Integration Options",
                "data": {
                    "scan_interval": "Poll interval (minutes)",
                    "pin": "Security PIN (leave blank to use initial value)",
                    "add_command_entities": "Add command entities (Button / Lock / Switch / Select)",
                    "log_level": "Log level"
                },
                "data_description": {
                    "log_level": "Changing the log level will reload the integration."
                }
            }
        }
    },
